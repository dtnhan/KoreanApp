# PostgreSQL connection string
# Local: DATABASE_URL và DIRECT_URL giống nhau.
# Neon (production): DATABASE_URL = chuỗi POOLED (host có "-pooler"); DIRECT_URL = chuỗi trực tiếp.
DATABASE_URL="postgresql://user:password@localhost:5432/hanngu"
DIRECT_URL="postgresql://user:password@localhost:5432/hanngu"

# Auth.js / NextAuth v5 — sinh khóa: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""

# URL gốc của site (production, ví dụ https://han-ngu.vercel.app). Local có thể để trống.
AUTH_URL=""

# Google OAuth (tùy chọn — điền để bật nút "Đăng nhập với Google")
# Redirect URI cần khai báo trong Google Cloud Console:
#   http://localhost:3000/api/auth/callback/google
#   https://<domain-production>/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Chỉ dùng khi seed production để đặt tài khoản admin an toàn (không bắt buộc ở local)
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""
